{
  "InstallerUpdater": {
    "UpdateServerUrl": "http://update-server.local",
    "PollIntervalMinutes": 60,
    "DownloadDirectory": "C:\\ProgramData\\InstallerUpdater\\updates",
    "TargetServiceName": "InstallerService",
    "MaxRetries": 3,
    "RegistryBasePath": "SOFTWARE\\rzwnz\\InstallerService",
    "HttpTimeoutSeconds": 120,
    "SilentInstall": true,
    "InstallerPath": "C:\\ProgramData\\InstallerUpdater\\updates\\InstallerUpdaterSetup.exe"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
